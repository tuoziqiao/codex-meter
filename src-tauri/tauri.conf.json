{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CodexMeter",
  "version": "0.1.3",
  "identifier": "app.quotafloat.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "widget",
        "title": "CodexMeter",
        "width": 320,
        "height": 320,
        "minWidth": 320,
        "minHeight": 320,
        "maxWidth": 360,
        "maxHeight": 360,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "visible": true
      }
    ],
    "security": { "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self'; img-src 'self' data:" }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "Codex quota at a glance",
    "longDescription": "A lightweight floating desktop card for Codex usage limits.",
    "copyright": "Copyright CodexMeter contributors",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
  }
}
