{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CodexMeter",
  "version": "0.2.0",
  "identifier": "app.quotafloat.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": { "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self'; img-src 'self' data:" }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "Codex quota in the title bar",
    "longDescription": "A lightweight tray utility that injects read-only Codex quota into the Codex Desktop title bar.",
    "copyright": "Copyright CodexMeter contributors",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "resources": ["resources/*"]
  }
}
